# ===========================================
# Proctor - AI Tutor Screener
# Environment Variables
# ===========================================

# ----- Web Frontend (apps/web) -----
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# ----- Server Backend (apps/server) -----
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001

# LiveKit Configuration (same Cloud project as NEXT_PUBLIC_LIVEKIT_URL and `lk agent deploy`)
# The server dispatches the registered cloud agent (name: tutor-screener) to each interview room when a token is issued.
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# Agent Authentication
AGENT_API_KEY=your-agent-api-key

# ----- Python Agent (apps/agent) -----
# OPENAI_API_KEY=sk-your-openai-key
# PROCTOR_API_URL=http://localhost:3000
# AGENT_API_KEY=your-agent-api-key
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your-livekit-api-key
# LIVEKIT_API_SECRET=your-livekit-api-secret

# ----- Infrastructure (packages/infra) -----
# Copy packages/infra/.env.example to packages/infra/.env and set ALCHEMY_STATE_TOKEN + CLOUDFLARE_API_TOKEN.
# Deploy: npm run deploy  (uses Cloudflare state when ALCHEMY_STATE_TOKEN is set)
# ALCHEMY_PASSWORD=your-alchemy-password
