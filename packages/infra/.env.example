# Copy to `.env` in this folder (gitignored). Used by `alchemy deploy` / `alchemy dev`.

# --- Required for `npm run deploy` (CI and local) ---
# Alchemy uses Cloudflare-backed state when this is set (avoids CI/local-state errors).
# Use the same value for every deploy to this account.
# openssl rand -base64 32
ALCHEMY_STATE_TOKEN=

# API token with Workers, D1, and account permissions (avoids broken OAuth in headless runs).
# https://developers.cloudflare.com/fundamentals/api/get-started/create-token/
CLOUDFLARE_API_TOKEN=

# Optional: encrypt secrets in local state files
# ALCHEMY_PASSWORD=

# --- Production URLs (set before deploy; use outputs from first deploy if needed) ---
# NEXT_PUBLIC_SERVER_URL=https://your-worker.workers.dev
# BETTER_AUTH_URL=https://your-web.pages.dev
# CORS_ORIGIN=https://your-web.pages.dev

# App secrets are loaded from ../../apps/web/.env and ../../apps/server/.env
# Ensure server has LIVEKIT_* and AGENT_API_KEY for the worker.
